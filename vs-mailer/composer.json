{
  "name": "vicedomini-softworks/vs-mailer",
  "description": "Complete SMTP, Brevo, and Mailgun email delivery plugin for WordPress.",
  "type": "wordpress-plugin",
  "license": "GPL-3.0-only",
  "require": {
    "php": ">=7.2.24"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.7",
    "phpstan/phpstan": "^1.10"
  },
  "scripts": {
    "phpcs": "phpcs --standard=phpcs.xml .",
    "phpstan": "phpstan analyse --configuration=phpstan.neon"
  },
  "config": {
    "allow-plugins": false
  }
}
