{
	"name": "vicedomini-softworks/v-secrets-manager",
	"description": "WordPress plugin to manage secrets with multiple providers: encrypted DB, AWS Secrets Manager, Hashicorp Vault / OpenBao.",
	"type": "wordpress-plugin",
	"license": "GPL-3.0-only",
	"require": {
		"php": ">=8.1",
		"aws/aws-sdk-php": "^3.0"
	},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"squizlabs/php_codesniffer": "^3.0",
		"wp-coding-standards/wpcs": "^3.0",
		"phpstan/phpstan": "^1.0",
		"szepeviktor/phpstan-wordpress": "^1.0"
	},
	"scripts": {
		"phpcs": "phpcs",
		"phpcbf": "phpcbf",
		"phpstan": "phpstan analyse --memory-limit=1G"
	},
	"config": {
		"optimize-autoloader": true,
		"platform": {
			"php": "8.1"
		},
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
