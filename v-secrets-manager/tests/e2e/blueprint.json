{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"landingPage": "/wp-admin/plugins.php",
	"preferredVersions": {
		"php": "8.0",
		"wp": "6.9"
	},
	"phpExtensionBundles": ["kitchen-sink"],
	"steps": [
		{
			"step": "installPlugin",
			"pluginZipFile": {
				"resource": "vfs",
				"path": "/wordpress/wp-content/plugins/v-secrets-manager"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "login",
			"username": "admin",
			"password": "password"
		}
	]
}
