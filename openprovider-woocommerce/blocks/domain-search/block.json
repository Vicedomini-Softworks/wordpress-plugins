{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "openprovider-woocommerce/domain-search",
	"title": "Domain Search",
	"category": "widgets",
	"icon": "search",
	"description": "Search and register domains via OpenProvider.",
	"textdomain": "openprovider-woocommerce",
	"attributes": {
		"defaultTlds": {
			"type": "array",
			"default": []
		},
		"buttonLabel": {
			"type": "string",
			"default": "Search"
		}
	},
	"supports": {
		"html": false
	},
	"editorScript": "file:./build/index.js",
	"editorStyle": "file:./build/index.css"
}
