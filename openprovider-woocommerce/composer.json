{
  "name": "vicedomini-softworks/openprovider-woocommerce",
  "description": "OpenProvider domain registrar integration for WooCommerce.",
  "type": "wordpress-plugin",
  "license": "GPL-3.0-only",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "squizlabs/php_codesniffer": "^3.0",
    "wp-coding-standards/wpcs": "^3.0",
    "phpstan/phpstan": "^2.0",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "php-stubs/woocommerce-stubs": "^9.0",
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "OpenProviderWooCommerce\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OpenProviderWooCommerce\\Tests\\": "tests/unit/"
    }
  },
  "scripts": {
    "phpcs": "phpcs",
    "phpcbf": "phpcbf",
    "phpstan": "phpstan analyse --memory-limit=1G",
    "test": "phpunit -c phpunit.xml.dist"
  },
  "config": {
    "optimize-autoloader": true,
    "platform": {
      "php": "8.1"
    },
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
